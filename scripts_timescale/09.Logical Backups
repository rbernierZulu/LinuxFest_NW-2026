#### CSV DUMPS AND UPLOADS ####
#

psql <<_eof_
    drop database if exists db02;
    create database db02;
    \c db02

    create extension timescaledb;

    create table t_timescale(
    id uuid
    ,c2 int default random()*1E6
    ,c3 int default random()*1E6
    ,c4 int default random()*1E6
    ,c5 int default random()*1E6
    ,c6 int default random()*1E6
    ,c7 int default random()*1E6
    ,t_stamp timestamptz not null default clock_timestamp()
    );

    select create_hypertable('t_timescale', 't_stamp');
    select * from set_chunk_time_interval('t_timescale',interval '1 minutes');
_eof_

#### CSV DUMP ####
# Time: 1m45s
time echo "copy (select * from t_timescale) to STDOUT with (format 'csv')" | psql ex02 > t_timescale.csv

# Time: 1m30s
time echo "copy (select * from t_timescale) to STDOUT with (format 'csv')" | psql ex02 | pigz -> t_timescale.pig.csv.gz

# Time: 6m25s
time echo "copy (select * from t_timescale) to STDOUT with (format 'csv')" | psql ex02 | gzip -> t_timescale.csv.gz


#### CSV UPLOAD ####
# Time: 7m50s
time cat t_timescale.csv | psql db02 -c "copy t_timescale from STDIN with (format 'csv')"

# Time: 4m30s
time gunzip --stdout t_timescale.csv.gz | psql db02 -c "copy t_timescale from STDIN with (format 'csv')"

# Time: 2m, # workers=2XCPU
time timescaledb-parallel-copy \
    --connection "host=/var/run/postgresql/ dbname=db02" \
    --table t_timescale \
    --file t_timescale.csv \
    --workers 14 \
    --reporting-period 30s

# Time: 2m, using process substitution
time timescaledb-parallel-copy \
    --connection "host=/var/run/postgresql/ dbname=db02" \
    --table t_timescale \
    --file <(gunzip --stdout t_timescale.csv.gz) \
    --workers 14 \
    --reporting-period 30s
